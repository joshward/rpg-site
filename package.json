{
  "name": "rpg-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "op": "op run --env-file=.env.local --",
    "dev": "next dev",
    "dev!": "npm run op next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format:check": "prettier --check .",
    "format:write": "prettier --write .",
    "db!": "npm run op drizzle-kit --",
    "db:gen!": "npm run op drizzle-kit -- generate --name",
    "db:migrate!": "npm run db! migrate",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "cron:notifications!": "npm run op -- npx tsx scripts/trigger-notifications.ts",
    "dev:test-dm!": "npm run op -- npx tsx scripts/test-dm.ts",
    "dev:test-global!": "npm run op -- npx tsx scripts/test-global.ts",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.0",
    "@better-fetch/fetch": "^1.1.21",
    "@neondatabase/serverless": "^1.1.0",
    "@radix-ui/colors": "^3.0.0",
    "@radix-ui/react-icons": "^1.3.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-form": "^1.29.0",
    "@tanstack/valibot-form-adapter": "^0.42.1",
    "better-auth": "^1.6.5",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.4",
    "next-plausible": "^4.0.0",
    "next-themes": "^0.4.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-markdown": "^10.1.0",
    "rpg-site": "file:",
    "tailwind-merge": "^3.5.0",
    "timespan-ts": "^1.0.5",
    "valibot": "^1.3.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.1.2",
    "@eslint/eslintrc": "^3",
    "@storybook/addon-a11y": "^10.3.5",
    "@storybook/addon-docs": "^10.3.5",
    "@storybook/addon-onboarding": "^10.3.5",
    "@storybook/addon-themes": "^10.3.5",
    "@storybook/addon-vitest": "^10.3.5",
    "@storybook/nextjs-vite": "^10.3.5",
    "@tailwindcss/postcss": "^4.0.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.2",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.1.3",
    "@vitest/browser-playwright": "^4.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "baseline-browser-mapping": "^2.10.20",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10",
    "eslint-config-next": "16.2.4",
    "eslint-plugin-storybook": "^10.3.5",
    "jsdom": "^29.0.2",
    "playwright": "^1.59.1",
    "prettier": "^3.8.3",
    "storybook": "^10.2.4",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vite": "^7.3.2",
    "vitest": "^4.1.2"
  },
  "overrides": {
    "better-auth": {
      "drizzle-orm": "$drizzle-orm"
    },
    "prisma": "^5.22.0",
    "@prisma/client": "^5.22.0",
    "@vitest/browser": "^4.1.0"
  },
  "volta": {
    "node": "22.22.0"
  }
}
